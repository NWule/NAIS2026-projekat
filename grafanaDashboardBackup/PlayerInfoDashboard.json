      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Team History",
          "description": "Fetches the teams based on a Cypher query from PlayerRecommendationService database.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "kniepdennis-neo4j-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "efpryu5bzoum8b"
                      },
                      "spec": {
                        "cypherQuery": "MATCH (p: Player)-[pf: PLAYS_FOR]->(t: Team) \r\nWHERE p.id = '${player}'\r\nRETURN t.name AS Name, \r\n       t.country AS Country, \r\n       pf.position AS Position, \r\n       toString(pf.startDate) AS StartDate, \r\n       COALESCE(toString(pf.endDate), 'Current Team') AS EndDate;"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
