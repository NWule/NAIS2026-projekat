    "editable": false,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Player Info",
          "description": "Fetches the player info from PlayerRecommendationService database.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "kniepdennis-neo4j-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "efpryu5bzoum8b"
                      },
                      "spec": {
                        "cypherQuery": "MATCH (p: Player) \r\nWHERE p.id = '${player}'\r\nRETURN p.name AS Name, \r\n       p.surname AS Surname, \r\n       p.nationality AS Nationality, \r\n       toString(p.dateOfBirth) AS DateOfBirth;"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
