        {
          "cypherQuery": "MATCH (c:Customer)-[p:PURCHASED]->(s:Seat)-[:IN_ZONE]->(z:Zone)<-[:HAS_ZONE]-(e:Event)\r\nWHERE c.isActive = true\r\nWITH c, COUNT(p) AS totalPurchases, SUM(p.price) AS totalSpent\r\nWHERE totalPurchases > 0\r\nRETURN c.name AS Ime, c.surname AS Prezime, c.email AS Email,\r\n       c.loyaltyPoints AS LoyaltyPoeni,\r\n       totalPurchases AS BrojKupovina,\r\n       round(totalSpent * 100) / 100.0 AS UkupnaPotrosnja\r\nORDER BY totalSpent DESC LIMIT 10",
